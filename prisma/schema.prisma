generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. HỆ THỐNG USER & PHÂN QUYỀN
// ==========================================
enum Role {
  GUEST
  USER
  ADMIN
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  name         String?
  phone        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// 2. HỆ THỐNG SẢN PHẨM (MẮT KÍNH & BỘ SƯU TẬP)
// ==========================================
model Collection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  thumbnail   String?  
  highlight   Boolean  @default(false) // <-- Thêm trường này
  
  glasses     Glass[]  
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Glass {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String?
  price        Float
  
  images       String[]   
  attributes   Json?      
  
  collectionId String     @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([collectionId])
}